{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/lib",
    "types": ["node"],
    "rootDir": "./src"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ],
  "references": [
    {
      "path": "../../infra/i18n/tsconfig.lib.json"
    },
    {
      "path": "../../contracts/tsconfig.lib.json"
    },
    {
      "path": "../../shared/tsconfig.lib.json"
    },
    {
      "path": "../../infra/database/tsconfig.lib.json"
    },
    {
      "path": "../../infra/storage/tsconfig.lib.json"
    },
    {
      "path": "../../infra/auth/tsconfig.lib.json"
    }
  ]
}
