# Cross-editor baseline — every editor (VS Code, JetBrains, Zed, Vim) honours this.
# Formatting beyond these primitives (quotes, width, trailing commas) is owned by
# Prettier (.prettierrc); the two agree, so neither fights the other.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown uses two trailing spaces as a hard line break — trimming would corrupt it.
[*.md]
trim_trailing_whitespace = false
