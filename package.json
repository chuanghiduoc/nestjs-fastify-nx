{
  "name": "nestjs-fastify-nx",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "postinstall": "node -e \"require('fs').existsSync('prisma/schema.prisma')&&require('child_process').execSync('pnpm exec prisma generate',{stdio:'inherit'})\"",
    "build": "nx run-many --target=build",
    "test": "nx run-many --target=test",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\" --ignore-path .prettierignore",
    "codegen": "orval --config orval.config.ts",
    "codegen:export": "nx run api:codegen-export",
    "codegen:full": "pnpm codegen:export && pnpm codegen",
    "gen:module": "bash scripts/gen-module.sh modules",
    "gen:composition": "bash scripts/gen-module.sh composition",
    "gen:lib": "nx g @nx/js:library",
    "gen:app": "nx g @nx/nest:application",
    "rm:project": "bash scripts/remove-project.sh",
    "graph": "nx graph",
    "sync": "nx sync",
    "reset": "nx reset",
    "clean": "nx reset && node -e \"const fs=require('fs');['dist','tmp','.nx/cache'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-presigned-post": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@bull-board/api": "^8.1.2",
    "@bull-board/fastify": "^8.1.2",
    "@fastify/compress": "^9.0.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/under-pressure": "^9.1.0",
    "@keyv/redis": "^5.1.6",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/mercurius": "^13.4.2",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.1.1",
