{
  "name": "nestjs-fastify-nx",
  "version": "1.2.0",
  "license": "MIT",
  "scripts": {
    "postinstall": "node -e \"require('fs').existsSync('prisma/schema.prisma')&&require('child_process').execSync('pnpm exec prisma generate',{stdio:'inherit'})\"",
    "prepare": "node -e \"process.env.CI||require('child_process').execSync('lefthook install',{stdio:'inherit'})\"",
    "build": "nx run-many --target=build",
    "test": "nx run-many --target=test",
    "lint": "nx affected --target=lint",
    "lint:all": "nx run-many --target=lint --all",
    "lint:fix": "nx affected --target=lint -- --fix",
    "lint:fix:all": "nx run-many --target=lint --all -- --fix",
    "typecheck": "nx affected --target=typecheck",
    "typecheck:all": "nx run-many --target=typecheck --all",
    "format": "prettier --write \"**/*.{ts,json,md}\" --ignore-path .prettierignore",
    "codegen": "orval --config orval.config.ts",
    "codegen:export": "nx run api:codegen-export",
    "codegen:full": "pnpm codegen:export && pnpm codegen",
    "gen:module": "bash scripts/gen-module.sh modules",
    "gen:composition": "bash scripts/gen-module.sh composition",
    "gen:lib": "nx g @nx/js:library",
    "gen:app": "nx g @nx/nest:application",
    "rm:project": "bash scripts/remove-project.sh",
    "graph": "nx graph",
    "release": "nx release",
    "release:dry": "nx release --dry-run",
    "sync": "nx sync",
    "reset": "nx reset",
    "clean": "node tools/scripts/clean-workspace.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-presigned-post": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@bull-board/api": "^8.1.2",
    "@bull-board/fastify": "^8.1.2",
    "@fastify/compress": "^9.1.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/under-pressure": "^9.1.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/mercurius": "^13.4.2",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.28",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/core": "^2.10.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.221.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.221.0",
    "@opentelemetry/resources": "^2.10.0",
    "@opentelemetry/sdk-metrics": "^2.10.0",
    "@opentelemetry/sdk-node": "^0.221.0",
    "@opentelemetry/sdk-trace-base": "^2.10.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@scalar/fastify-api-reference": "^1.63.0",
    "@sentry/nestjs": "^10.67.0",
    "@sentry/profiling-node": "^10.67.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.18.1",
    "better-auth": "^1.6.24",
    "bullmq": "^5.80.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie": "^1.1.1",
    "eventemitter2": "^6.4.9",
    "fastify": "^5.10.0",
    "graphql": "^16.14.2",
    "ioredis": "^5.11.1",
    "mercurius": "^16.10.0",
    "nestjs-cls": "^6.2.1",
    "nestjs-i18n": "^10.8.5",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.9.0",
    "prom-client": "^15.1.3",
    "proxy-addr": "^2.0.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "tslib": "^2.8.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@apiture/openapi-down-convert": "^0.14.2",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@nx/devkit": "23.1.0",
    "@nx/eslint": "23.1.0",
    "@nx/eslint-plugin": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/nest": "23.1.0",
    "@nx/node": "23.1.0",
    "@nx/vite": "23.1.0",
    "@nx/vitest": "23.1.0",
    "@nx/web": "23.1.0",
    "@nx/webpack": "23.1.0",
    "@swc-node/register": "~1.12.1",
    "@swc/core": "~1.15.46",
    "@swc/helpers": "~0.5.23",
    "@testcontainers/postgresql": "^12.0.4",
    "@testcontainers/redis": "^12.0.4",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/proxy-addr": "^2.0.3",
    "@types/supertest": "^7.2.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "~4.1.10",
    "eslint": "^10.7.0",
    "lefthook": "^2.1.10",
    "lint-staged": "^17.1.1",
    "nx": "23.1.0",
    "orval": "^8.22.0",
    "pino-pretty": "^13.1.3",
    "prettier": "~3.9.6",
    "supertest": "^7.2.2",
    "swc-loader": "^0.2.7",
    "testcontainers": "^12.0.4",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "~4.1.10",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.14.0",
  "prisma": {
    "schema": "prisma/schema.prisma",
    "config": "prisma.config.ts",
    "seed": "node prisma/seed.mjs"
  }
}
