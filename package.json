  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/devkit": "^22.7.0",
    "@nx/eslint": "^22.7.0",
    "@nx/eslint-plugin": "^22.7.0",
    "@nx/js": "^22.7.0",
    "@nx/nest": "^22.7.0",
    "@nx/node": "22.7.1",
    "@nx/vite": "22.7.1",
    "@nx/vitest": "^22.7.0",
    "@nx/web": "22.7.1",
    "@nx/webpack": "22.7.1",
