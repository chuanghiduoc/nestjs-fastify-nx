    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "axios": "^1.18.1",
    "better-auth": "^1.6.23",
    "bullmq": "^5.80.2",
    "cache-manager": "^7.2.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eventemitter2": "^6.4.9",
    "fastify": "^5.10.0",
    "graphql": "^16.14.2",
    "ioredis": "^5.11.1",
    "mercurius": "^16.9.0",
    "nestjs-cls": "^6.2.1",
    "nestjs-i18n": "^10.8.5",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "tslib": "^2.8.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@apiture/openapi-down-convert": "^0.14.2",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@nx/devkit": "23.0.2",
    "@nx/eslint": "23.0.2",
    "@nx/eslint-plugin": "23.0.2",
    "@nx/js": "23.0.2",
    "@nx/nest": "23.0.2",
    "@nx/node": "23.0.2",
    "@nx/vite": "23.0.2",
    "@nx/vitest": "23.0.2",
    "@nx/web": "23.0.2",
    "@nx/webpack": "23.0.2",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.43",
    "@swc/helpers": "~0.5.23",
    "@testcontainers/postgresql": "^12.0.4",
    "@testcontainers/redis": "^12.0.4",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "~4.1.10",
    "eslint": "^10.7.0",
    "lefthook": "^2.1.10",
    "lint-staged": "^17.0.8",
    "nx": "23.0.2",
    "orval": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "prettier": "~3.9.5",
    "supertest": "^7.2.2",
    "swc-loader": "^0.2.7",
    "testcontainers": "^12.0.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "~4.1.10",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "prisma": {
    "schema": "prisma/schema.prisma",
    "config": "prisma.config.ts",
    "seed": "node prisma/seed.mjs"
  },
  "pnpm": {
    "overrides": {
      "fastify": ">=5.8.5",
      "@hono/node-server": ">=1.19.13",
      "brace-expansion": ">=5.0.6",
      "yaml": ">=2.8.3",
