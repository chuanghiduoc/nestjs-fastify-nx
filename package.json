    "@sentry/nestjs": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "axios": "^1.15.2",
    "better-auth": "^1.6.9",
    "bullmq": "^5.76.2",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eventemitter2": "^6.4.9",
    "fastify": "^5.8.5",
    "graphql": "^16.13.2",
    "ioredis": "^5.10.1",
    "mercurius": "^16.9.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
