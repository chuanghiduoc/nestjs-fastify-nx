{
  "uid": "queue-health",
  "title": "Queue Health",
  "tags": ["nestjs", "bullmq"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Queue depth by state",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (queue, state) (bullmq_queue_depth)",
          "legendFormat": "{{queue}} / {{state}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Job throughput (jobs/s by status)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (queue, status) (rate(bullmq_jobs_total[5m]))",
          "legendFormat": "{{queue}} / {{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Waiting backlog (max across replicas)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (queue) (bullmq_queue_depth{state=\"waiting\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Job duration p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, queue) (rate(bullmq_job_duration_seconds_bucket[5m])))",
          "legendFormat": "{{queue}}"
        }
      ]
    }
  ]
}
