generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name          String    @default("")
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("USER")
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // The @unique on email already creates a B-tree — a separate @@index([email])
  // would just duplicate writes for zero query benefit, so it is intentionally
  // omitted here.
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([status, updatedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verifications")
}

// `id` is application-stamped UUIDv7 — producer needs the value inside the
// same transaction to correlate aggregate writes with the outbox row.
model OutboxEvent {
  id          String    @id @db.Uuid
  eventType   String
  aggregateId String
  payload     Json
  processedAt DateTime?
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())

  // Relay scan path — must come first because (processedAt, createdAt) is the
  // leftmost prefix `WHERE processedAt IS NULL ORDER BY createdAt` uses.
  @@index([processedAt, createdAt])
  // Ops debugging path — "show me all undelivered users.registered events".
  // Without this, the only access path is a full scan of outbox_events.
  @@index([eventType, processedAt])
  @@map("outbox_events")
}

// `userId` intentionally has no FK — audit must survive User deletion.
// Range-partitioned monthly by `createdAt` (see migration
// `partition_audit_logs`). Postgres requires the partition key to participate
// in the primary key, hence the composite `@@id([id, createdAt])` —
// application stamps UUIDv7 ids so id-only uniqueness is preserved by
// construction even though no global UNIQUE constraint enforces it.
model AuditLog {
  id        String   @db.Uuid
  userId    String?  @db.Uuid
  action    String
  resource  String?
  metadata  Json
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@id([id, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  // Compliance query path — "every admin action on resource X in window Y".
  // Two-column index with createdAt last so it remains useful for range scans.
  @@index([resource, createdAt])
  @@map("audit_logs")
}
