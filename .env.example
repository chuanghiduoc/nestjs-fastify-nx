# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nestjs_db
POSTGRES_PORT=5432
# DATABASE_URL is the connection string used by the app at runtime.
# When running behind a transaction-mode pooler (pgbouncer, RDS Proxy, Supavisor),
# this should point at the pooler endpoint (e.g. pgbouncer:6432). Otherwise point
# directly at Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_db
# DATABASE_DIRECT_URL is OPTIONAL — only set when DATABASE_URL points at a pooler.
# Prisma CLI (migrate dev, generate) and the migration container use this to bypass
# the pooler so DDL statements work correctly (DDL requires session-scoped state that
# transaction mode cannot provide). When unset, Prisma CLI falls back to DATABASE_URL.
# Use cases: self-hosted pgbouncer, AWS RDS Proxy, Supabase Supavisor.
# Example (pgbouncer overlay): DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/nestjs_db
DATABASE_DIRECT_URL=
# PgBouncer tuning (only relevant when using examples/pgbouncer/ overlay)
PGBOUNCER_POOL_SIZE=30
PGBOUNCER_MAX_CLIENT_CONN=500
# Optional: route read-only queries (admin list users, audit log scans, GraphQL `users`
# resolver) to a Postgres physical replica. Leave empty to keep all queries on the primary
# (single-node deployment — the default).
#
# Better Auth, outbox relay, and command handlers ALWAYS use the primary — they require
# read-your-writes correctness. The replica is opt-in per repository method.
#
# When using the pgbouncer overlay, route both URLs through it:
#   DATABASE_URL=postgresql://app:pwd@pgbouncer:6432/nestjs_db
#   DATABASE_REPLICA_URL=postgresql://app:pwd@pgbouncer:6432/nestjs_db_read
# (nestjs_db_read is defined in examples/pgbouncer/pgbouncer.ini and points at the
# replica host — the pooler multiplexes connections on the read side too.)
#
# The Postgres role used by DATABASE_REPLICA_URL SHOULD be GRANT SELECT only —
# defence-in-depth against accidental writes through the read path.
DATABASE_REPLICA_URL=
DATABASE_REPLICA_POOL_MAX=10
# pg pool tuning — tune POOL_MAX based on your Postgres max_connections and number of api instances
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=0
DATABASE_IDLE_TIMEOUT_MS=10000
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_APPLICATION_NAME=nestjs-fastify-api

# Redis Cache
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
# Default TTL applied by cache-manager when set() is called without an explicit ttl.
REDIS_CACHE_TTL_MS=300000

# Redis Queue
REDIS_QUEUE_HOST=localhost
REDIS_QUEUE_PORT=6380
# BullMQ key prefix; override per environment (e.g. "myapp:prod") to share a Redis instance safely.
REDIS_QUEUE_PREFIX=bull
# Logical Redis DB used by Socket.io's pub/sub adapter so it doesn't collide with
# cache (db 0) or BullMQ (uses prefixed keys on db 0). Any 0–15 works.
REDIS_PUBSUB_DB=2

# MinIO / S3
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=uploads
# Region tag used by the S3 client; MinIO ignores it but real AWS / Cloudflare R2 require a real value.
STORAGE_REGION=us-east-1

# App
NODE_ENV=development
PORT=3000

# Timezone — applied to all containers (api, worker, scheduler, migration, postgres,
# redis, minio, mailpit). Default UTC keeps logs, audit timestamps, BullMQ delayed
# jobs and DB `now()` aligned across environments. The 4 Node images ship `tzdata`
# so any IANA name works (e.g. `Asia/Ho_Chi_Minh`, `Europe/Berlin`); prefer UTC at
# runtime and convert to local TZ at the UI layer unless the business truly needs
# local time on the backend.
TZ=UTC

# Production image references (used by docker/compose.prod.yml — leave blank in dev)
# IMAGE_NAMESPACE matches the GHCR path, e.g. `your-org/your-repo` for
# `ghcr.io/your-org/your-repo/api:latest`. IMAGE_TAG can be `latest` for rolling
# deploys or a pinned version like `1.2.3`.
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=
IMAGE_TAG=latest
API_PORT=3000

# Auth — Better Auth (session-based)
# BETTER_AUTH_SECRET signs session tokens. Must be at least 32 chars and stable across
# restarts (rotate via key-rolling, not sudden replacement). Required in production.
# In dev you can leave it blank — Better Auth will generate an ephemeral one per boot,
# which is fine for development but invalidates sessions after every restart.
BETTER_AUTH_SECRET=
# Public base URL of the API (e.g. https://api.example.com). Optional in dev.
# Required in prod when running behind a load balancer for proper cookie domain
# scoping and email link generation.
BETTER_AUTH_URL=

# Public origin of the frontend SPA — owns the pages /reset, /verify-email,
# /delete-account that receive the tokenized link sent by email. The SPA
# reads ?token=... from the URL, shows a form, and POSTs to the matching
# /api/auth/* endpoint. The backend never renders HTML for these flows.
# REQUIRED in production (boot fails otherwise). In dev, leaving it blank
# falls back to BETTER_AUTH_URL with a warning — the email link will 404
# in a browser but BullMQ + smoke tests still work.
FRONTEND_BASE_URL=

# Number of reverse-proxy hops between the edge and the api container.
# Fastify uses this to resolve `req.ip` from X-Forwarded-For. Single nginx = 1,
# nginx + LB = 2. The WS per-IP cap and metrics guard use raw TCP socket addr
# and are NOT affected by this value.
TRUST_PROXY_HOPS=1

# CORS (comma-separated origins, leave empty to disable)
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# Rate Limiter (NestJS ThrottlerGuard — applies to all Nest-handled routes)
THROTTLER_ENABLED=true
THROTTLER_LIMIT=100
THROTTLER_TTL=60

# Auth rate limit — two-tier (Auth0/Cognito pattern).
# STRICT: credential endpoints, 5/15min per IP+email.
# LOOSE: session ops, 60/min per IP.
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_SESSION_RATE_LIMIT_MAX=60
AUTH_SESSION_RATE_LIMIT_WINDOW_MS=60000

# HTTP body size caps — 1 MB for JSON, 10 MB for multipart file uploads.
# Increase UPLOAD_MAX_FILE_BYTES if your use-case requires larger uploads.
HTTP_BODY_LIMIT_BYTES=1048576
UPLOAD_MAX_FILE_BYTES=10485760

# Mail (mailpit SMTP for dev — UI at http://localhost:8025)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@example.com
MAIL_DEFAULT_NAME="No Reply"
MAILPIT_UI_PORT=8025

# API host ports for docker compose (container internal port stays 3000/9229)
API_PORT=3000
API_DEBUG_PORT=9229

# Admin seed (run once at migration)
# RUN_SEED gates the seed step inside the migration container — set to `true`
# explicitly when you want the first-boot admin user created. SEED_ADMIN_EMAIL
# and SEED_ADMIN_PASSWORD are required only when RUN_SEED=true.
RUN_SEED=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Observability
LOG_LEVEL=info
ENABLE_METRICS=false
# Comma-separated CIDRs allowed to scrape /metrics. Loopback (127.0.0.1, ::1)
# is always permitted. Empty = loopback-only (recommended for production).
# Kubernetes example: "10.244.0.0/16" (pod CIDR where Prometheus runs).
#
# WARNING: The /metrics guard uses socket remoteAddress (not X-Forwarded-For).
# Configure CIDRs as the direct client IPs reaching the API process — i.e. the
# Prometheus pod CIDR or the internal LB address, not the end-user IPs seen by
# the edge proxy. Prefer binding /metrics on a separate internal port via a
# reverse proxy so it is never reachable from the public internet.
METRICS_ALLOW_CIDRS=
# Gauges exposed at /metrics (when ENABLE_METRICS=true):
#   bullmq_queue_depth{queue, state}  — job backlog per queue (polled every 30s)
#   outbox_lag_seconds                — age of oldest unprocessed outbox event (polled every 30s)
# METRICS_ALLOW_CIDRS controls which Prometheus scrapers can reach these gauges.

# OpenTelemetry (toggle with OTEL_ENABLED — exporter targets an OTLP/HTTP collector,
# e.g. otel-collector, Tempo, Jaeger, Honeycomb, Grafana Cloud)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=nestjs-fastify-api
OTEL_SERVICE_NAMESPACE=app
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Comma-separated key=value pairs (e.g. for vendor auth tokens)
OTEL_EXPORTER_OTLP_HEADERS=
# 0..1 — fraction of traces to sample (1 = all, 0 = none)
OTEL_TRACES_SAMPLER_RATIO=1
# Set to true to print SDK diagnostics to stderr while debugging
OTEL_DEBUG=false

# Domain event publisher
# inprocess  → emit events synchronously via EventEmitter2 (default, dev-friendly)
# outbox     → persist events to Postgres outbox_events; the scheduler relays them
EVENT_PUBLISHER_DRIVER=inprocess
# Polling cadence and batch sizing for the outbox relay (only used when DRIVER=outbox)
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10
# Prisma interactive-transaction timeout for the relay's claim+publish+mark cycle.
# Increase if batchSize is large or listeners do synchronous DB work (e.g. audit-log).
# The Prisma default of 5000 ms risks P2028 rollback → duplicate event re-publish.
OUTBOX_TX_TIMEOUT_MS=30000

# Audit retention — number of monthly audit_logs partitions to keep. Anything
# older is dropped on the 1st of each month by the scheduler. 12 ≈ one year.
AUDIT_LOG_RETENTION_MONTHS=12

# Outbox event retention — processed outbox rows older than this are hard-deleted
# daily at 03:15 UTC by the scheduler. Unprocessed rows (processedAt IS NULL) are
# never deleted by this cron — they keep retrying until OUTBOX_MAX_ATTEMPTS.
OUTBOX_RETENTION_DAYS=7

# Outbox purge throughput per cron run (BATCH_SIZE rows × MAX_BATCHES iterations).
# Defaults handle ~1M rows/day comfortably. Raise OUTBOX_PURGE_MAX_BATCHES at
# higher event volumes — otherwise the backlog grows faster than the cron drains
# and the table bloats. Monitor via the scheduler log line `Outbox purge complete`
# and the outbox_lag_seconds gauge (rising lag = relay can't keep up).
OUTBOX_PURGE_BATCH_SIZE=1000
OUTBOX_PURGE_MAX_BATCHES=200

# Bull Board (queue UI mounted at /api/admin/queues, protected by HTTP Basic auth)
# Disable in production if you front it with a separate ingress / SSO instead.
BULL_BOARD_ENABLED=true
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=admin

# Horizontal scaling — consumed by docker compose / swarm, NOT by app code.
# Set API_REPLICAS / WORKER_REPLICAS in your deploy environment (.env or swarm secrets).
# Connection pool budget: (API_REPLICAS + 1) × DATABASE_POOL_MAX must stay ≤ 80
# until PgBouncer is in front of Postgres.
API_REPLICAS=1
WORKER_REPLICAS=1
# Scheduler runs exactly 1 container — cron jobs would otherwise double-fire.
# Never set WORKER_REPLICAS=N for the scheduler service.

# Per-queue worker concurrency (jobs processed in parallel per replica).
# Default 5 is conservative. For I/O-bound queues (email, S3 verify) you can
# raise to 20–50 before scaling WORKER_REPLICAS. Effective parallelism =
# WORKER_<QUEUE>_CONCURRENCY × WORKER_REPLICAS.
WORKER_EMAIL_CONCURRENCY=5
WORKER_UPLOAD_CONCURRENCY=5

# Sentry (leave SENTRY_DSN blank to disable error reporting)
# DSN format: https://<key>@oXXXXX.ingest.sentry.io/<projectId>
SENTRY_DSN=
# 0..1 — fraction of transactions to send (0.1 = 10%). Lower in high-traffic prod.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Free-form tag (development | staging | production). Surfaces in Sentry UI filters.
SENTRY_ENVIRONMENT=development
