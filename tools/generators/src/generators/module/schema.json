{
  "$schema": "http://json-schema.org/schema",
  "$id": "ModuleGenerator",
  "title": "DDD Module Generator",
  "description": "Scaffold a new DDD module with domain/application/infrastructure/presentation layers",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Module name (kebab-case, e.g. 'users', 'orders')",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "What is the module name? (kebab-case)"
    },
    "directory": {
      "type": "string",
      "description": "Target scope: 'modules' (default) for bounded contexts, 'composition' for cross-cutting aggregates",
      "enum": ["modules", "composition"],
      "default": "modules"
    },
    "withCqrs": {
      "type": "boolean",
      "description": "Include CQRS command skeleton",
      "default": true
    }
  },
  "required": ["name"]
}
