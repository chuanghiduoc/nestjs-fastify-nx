import { generateId } from '@nestjs-fastify-nx/shared';
import { <%= className %> } from '../domain/entities/<%= fileName %>.entity';

let counter = 0;

export class <%= className %>Factory {
  static create(): <%= className %> {
    counter++;
    return <%= className %>.reconstitute({
      id: generateId(),
      createdAt: new Date(),
      updatedAt: new Date(),
    });
  }

  static reset(): void {
    counter = 0;
  }
}
