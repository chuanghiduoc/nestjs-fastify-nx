{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": ["scope:api"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/api"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "codegen-build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "^build",
        {
          "projects": ["infra-database"],
          "target": "prisma-generate",
          "params": "ignore"
        }
      ],
      "inputs": ["backendBuild", "^production"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/api-codegen"],
      "options": {
        "command": "webpack-cli build --config webpack.codegen.config.js --node-env=development",
        "cwd": "apps/api"
      }
    },
    "codegen-export": {
      "executor": "nx:run-commands",
      "dependsOn": ["codegen-build"],
      "cache": true,
      "inputs": ["sharedGlobals", "{workspaceRoot}/dist/apps/api-codegen/**/*"],
      "outputs": ["{workspaceRoot}/dist/swagger"],
      "options": {
        "command": "node dist/apps/api-codegen/main.js"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "api:build",
        "runBuildTargetDependencies": false,
        "runtimeArgs": ["--env-file-if-exists=.env"],
        "watch": true
      },
      "configurations": {
        "development": {
          "buildTarget": "api:build:development"
        },
        "production": {
          "buildTarget": "api:build:production"
        }
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "parallelism": false,
      "dependsOn": [
        {
          "projects": ["infra-database"],
          "target": "prisma-generate",
          "params": "ignore"
        }
      ],
      "options": {
        "command": "vitest --run --config apps/api/vite.e2e.config.ts"
      }
    }
  }
}
