{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": ["node"],
    "rootDir": "./src"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ],
  "references": [
    {
      "path": "../../libs/shared/tsconfig.lib.json"
    },
    {
      "path": "../../libs/infra/redis/tsconfig.lib.json"
    },
    {
      "path": "../../libs/modules/audit-log/tsconfig.lib.json"
    },
    {
      "path": "../../libs/modules/users/tsconfig.lib.json"
    },
    {
      "path": "../../libs/infra/observability/tsconfig.lib.json"
    },
    {
      "path": "../../libs/infra/messaging/tsconfig.lib.json"
    },
    {
      "path": "../../libs/infra/storage/tsconfig.lib.json"
    },
    {
      "path": "../../libs/infra/database/tsconfig.lib.json"
    },
    {
      "path": "../../libs/core/tsconfig.lib.json"
    }
  ]
}
